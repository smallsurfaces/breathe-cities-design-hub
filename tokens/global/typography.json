{
  "font": {
    "family": {
      "sans": {
        "$value": "Söhne, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
        "$type": "fontFamily",
        "$description": "Primary sans-serif — Söhne (self-hosted, 3 weights)"
      },
      "mono": {
        "$value": "'Aeonik Mono', ui-monospace, monospace",
        "$type": "fontFamily",
        "$description": "Monospace — code blocks and pre tags"
      }
    },
    "weight": {
      "light":  { "$value": "300", "$type": "fontWeight", "$description": "Söhne Buch" },
      "medium": { "$value": "500", "$type": "fontWeight", "$description": "Söhne Halbfett" },
      "bold":   { "$value": "700", "$type": "fontWeight", "$description": "Söhne Kraftig" }
    },
    "size": {
      "titleLarge":  { "$value": "4rem",    "$type": "fontSize", "$description": "Hero headings — scales to 5.25rem at 1600px+" },
      "titleMedium": { "$value": "2.125rem","$type": "fontSize", "$description": "Section headings — scales to 2.875rem at 1600px+" },
      "titleSmall":  { "$value": "1.25rem", "$type": "fontSize", "$description": "Subsection headings — scales to 2.125rem at 1600px+" },
      "titleSub":    { "$value": "1.125rem","$type": "fontSize", "$description": "Sub-headings — scales to 1.625rem at 1600px+" },
      "body":        { "$value": "1rem",    "$type": "fontSize", "$description": "Body text — scales to 1.25rem at 1600px+" },
      "bodySmall":   { "$value": "1rem",    "$type": "fontSize", "$description": "Small body — scales to 1.125rem at 1600px+" },
      "bodySmaller": { "$value": "0.875rem","$type": "fontSize", "$description": "Extra small body" },
      "caption":     { "$value": "0.938rem","$type": "fontSize", "$description": "Captions and labels" },
      "linkSmall":   { "$value": "0.75rem", "$type": "fontSize", "$description": "Small link text" }
    },
    "lineHeight": {
      "tight":    { "$value": "1.09",  "$type": "lineHeight", "$description": "Tight — large headings" },
      "snug":     { "$value": "1.25",  "$type": "lineHeight", "$description": "Snug — subheadings" },
      "normal":   { "$value": "1.44",  "$type": "lineHeight", "$description": "Normal — body text" },
      "relaxed":  { "$value": "1.5",   "$type": "lineHeight", "$description": "Relaxed — readable paragraphs" }
    },
    "letterSpacing": {
      "default": { "$value": "0px",   "$type": "letterSpacing" },
      "wide":    { "$value": "0.5px", "$type": "letterSpacing" }
    }
  }
}
